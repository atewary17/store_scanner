<%# app/views/admin/dashboard/index.html.erb %>
<div class="min-h-screen bg-gray-50">

  <%# Navbar %>
  <nav class="bg-gray-900 text-white px-6 py-4 flex justify-between items-center">
    <h1 class="font-bold text-lg">🔧 Store Scanner — Admin</h1>
    <div class="flex gap-4 text-sm items-center">
      <%= link_to "Products",    admin_products_path,      class: "text-gray-300 hover:text-white" %>
      <%= link_to "Export Excel", admin_exports_excel_path(format: :xlsx),
                  class: "bg-green-600 px-3 py-1 rounded-lg text-white" %>
      <%= link_to "Logout", admin_logout_path, data: { turbo_method: :delete },
                  class: "text-red-400 hover:text-red-300" %>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-8 space-y-8">

    <%# Stats row %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% [
        ["Total Products", @total_products, "blue"],
        ["Scan Sessions",  @total_sessions, "purple"],
        ["Via API",        @by_source['upcitemdb'].to_i + @by_source['go_upc'].to_i, "green"],
        ["Manual/OCR",     @by_source['manual'].to_i + @by_source['google_vision'].to_i, "orange"]
      ].each do |label, count, color| %>
        <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-<%= color %>-500">
          <p class="text-2xl font-bold text-<%= color %>-600"><%= count %></p>
          <p class="text-sm text-gray-500"><%= label %></p>
        </div>
      <% end %>
    </div>

    <%# Source breakdown %>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl shadow-sm p-5">
        <h3 class="font-semibold text-gray-700 mb-3">By Data Source</h3>
        <div class="space-y-2">
          <% @by_source.sort_by { |_, v| -v }.each do |source, count| %>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600"><%= source&.humanize || 'Unknown' %></span>
              <div class="flex items-center gap-2">
                <div class="bg-blue-200 rounded-full h-2"
                     style="width:<%= [count * 80 / [@by_source.values.max, 1].max, 80].min %>px">
                </div>
                <span class="text-sm font-bold text-gray-700"><%= count %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-5">
        <h3 class="font-semibold text-gray-700 mb-3">By Category</h3>
        <div class="space-y-2">
          <% @by_category.sort_by { |_, v| -v }.each do |cat, count| %>
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">
                <%= product_emoji(cat) %> <%= cat.presence || 'Uncategorised' %>
              </span>
              <span class="text-sm font-bold text-gray-700"><%= count %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Recent products table %>
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b flex justify-between items-center">
        <h3 class="font-semibold text-gray-700">Recent Products</h3>
        <%= link_to "View All →", admin_products_path, class: "text-sm text-blue-600" %>
      </div>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
          <tr>
            <th class="px-4 py-3 text-left">Name</th>
            <th class="px-4 py-3 text-left">Brand</th>
            <th class="px-4 py-3 text-left">Category</th>
            <th class="px-4 py-3 text-left">Source</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% @products.first(10).each do |product| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-800"><%= product.name %></td>
              <td class="px-4 py-3 text-gray-500"><%= product.brand %></td>
              <td class="px-4 py-3">
                <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">
                  <%= product.category %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-400 text-xs"><%= product.source %></td>
              <td class="px-4 py-3">
                <%= link_to "Edit", edit_admin_product_path(product),
                      class: "text-blue-600 hover:underline text-xs mr-2" %>
                <%= link_to "Delete", admin_product_path(product),
                      data: { turbo_method: :delete, turbo_confirm: "Delete this product?" },
                      class: "text-red-500 hover:underline text-xs" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>