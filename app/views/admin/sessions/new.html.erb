<%# app/views/admin/sessions/new.html.erb %>
<div class="min-h-screen bg-gray-100 flex items-center justify-center px-4">
  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-sm">
    <div class="text-center mb-6">
      <span class="text-5xl">🔐</span>
      <h1 class="text-xl font-bold mt-2 text-gray-800">Admin Access</h1>
      <p class="text-gray-500 text-sm">Store Scanner Admin Panel</p>
    </div>
    <% if flash[:error] %>
      <div class="bg-red-50 text-red-600 text-sm px-3 py-2 rounded-lg mb-4">
        <%= flash[:error] %>
      </div>
    <% end %>
    <%= form_with url: admin_login_path, method: :post do |f| %>
      <div class="mb-4">
        <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password,
              class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800",
              placeholder: "Enter admin password" %>
      </div>
      <%= f.submit "Enter Admin Panel →",
            class: "w-full bg-blue-600 text-white py-3 rounded-xl font-bold" %>
    <% end %>
  </div>
</div>