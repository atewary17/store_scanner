<%# app/views/dashboard/index.html.erb %>
<div class="min-h-screen bg-gray-50">

  <%# Header %>
  <div class="bg-blue-700 text-white px-4 py-5">
    <h1 class="text-xl font-bold">📦 Store Scanner</h1>
    <p class="text-blue-200 text-sm">Product catalogue builder</p>
  </div>

  <%# Quick Action Buttons %>
  <div class="px-4 py-4 grid grid-cols-2 gap-3">
    <%= link_to new_scan_session_path,
          class: "bg-blue-600 text-white rounded-xl p-4 flex flex-col items-center shadow" do %>
      <span class="text-3xl">📷</span>
      <span class="font-semibold mt-1">New Scan</span>
      <span class="text-xs text-blue-200">Start a store visit</span>
    <% end %>

    <%= link_to products_path,
          class: "bg-white text-gray-800 rounded-xl p-4 flex flex-col items-center shadow border" do %>
      <span class="text-3xl">📋</span>
      <span class="font-semibold mt-1">Products</span>
      <span class="text-xs text-gray-500">Browse catalogue</span>
    <% end %>

    <%= link_to scan_sessions_path,
          class: "bg-white text-gray-800 rounded-xl p-4 flex flex-col items-center shadow border" do %>
      <span class="text-3xl">🗂️</span>
      <span class="font-semibold mt-1">Sessions</span>
      <span class="text-xs text-gray-500">Past store visits</span>
    <% end %>

    <%= link_to admin_exports_excel_path, format: :xlsx,
          class: "bg-green-600 text-white rounded-xl p-4 flex flex-col items-center shadow" do %>
      <span class="text-3xl">📊</span>
      <span class="font-semibold mt-1">Export</span>
      <span class="text-xs text-green-200">Download Excel</span>
    <% end %>
  </div>

  <%# Stats Cards %>
  <div class="px-4 pb-4">
    <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">Overview</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-blue-500">
        <p class="text-3xl font-bold text-blue-600"><%= @total_products %></p>
        <p class="text-sm text-gray-500">Total Products</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-purple-500">
        <p class="text-3xl font-bold text-purple-600"><%= @total_scans %></p>
        <p class="text-sm text-gray-500">Total Scans</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-green-500">
        <p class="text-3xl font-bold text-green-600"><%= @scans_today %></p>
        <p class="text-sm text-gray-500">Scanned Today</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-orange-500">
        <p class="text-3xl font-bold text-orange-600"><%= @total_sessions %></p>
        <p class="text-sm text-gray-500">Store Visits</p>
      </div>
    </div>
  </div>

  <%# Data Source Breakdown %>
  <div class="px-4 pb-4">
    <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">Data Sources</h2>
    <div class="bg-white rounded-xl shadow-sm p-4 space-y-3">
      <div class="flex justify-between items-center">
        <span class="text-sm text-gray-600">🌐 Found via API</span>
        <span class="font-bold text-green-600"><%= @api_entries %></span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-sm text-gray-600">📷 Google Vision OCR</span>
        <span class="font-bold text-blue-600"><%= @vision_entries %></span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-sm text-gray-600">✏️ Manually Entered</span>
        <span class="font-bold text-orange-600"><%= @manual_entries %></span>
      </div>
    </div>
  </div>

  <%# Categories %>
  <% if @categories.any? %>
  <div class="px-4 pb-4">
    <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">By Category</h2>
    <div class="bg-white rounded-xl shadow-sm divide-y">
      <% @categories.sort_by { |_, v| -v }.each do |category, count| %>
        <div class="flex justify-between items-center px-4 py-3">
          <span class="text-sm text-gray-700"><%= category.presence || "Uncategorised" %></span>
          <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded-full">
            <%= count %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <%# Recent Products %>
  <div class="px-4 pb-8">
    <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">Recently Added</h2>
    <div class="space-y-2">
      <% @recent_products.each do |product| %>
        <%= link_to product_path(product),
              class: "bg-white rounded-xl p-3 flex items-center gap-3 shadow-sm block" do %>
          <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center text-lg">
            <%= product_emoji(product.category) %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm text-gray-800 truncate"><%= product.name %></p>
            <p class="text-xs text-gray-500"><%= product.brand %> · <%= product.category %></p>
          </div>
          <span class="text-xs text-gray-400"><%= time_ago_in_words(product.created_at) %> ago</span>
        <% end %>
      <% end %>
    </div>
  </div>

</div>