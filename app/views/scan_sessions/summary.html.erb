<div class="min-h-screen bg-gray-50">
  <div class="bg-blue-700 text-white px-4 py-5 flex items-center gap-3">
    <%= link_to scan_session_path(@scan_session), class: "text-blue-200 text-sm" do %>← Back<% end %>
    <div>
      <h1 class="text-xl font-bold"><%= @scan_session.name %></h1>
      <p class="text-blue-200 text-sm"><%= @scan_session.location %> · <%= @scan_session.scanned_on&.strftime('%d %b %Y') %></p>
    </div>
  </div>

  <div class="px-4 py-4">
    <div class="grid grid-cols-2 gap-3 mb-6">
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-blue-500">
        <p class="text-2xl font-bold text-blue-600"><%= @scan_items.count %></p>
        <p class="text-sm text-gray-500">Total Items</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-purple-500">
        <p class="text-2xl font-bold text-purple-600"><%= @by_category.keys.count %></p>
        <p class="text-sm text-gray-500">Categories</p>
      </div>
    </div>

    <% @by_category.each do |category, items| %>
      <div class="mb-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-2">
          <%= product_emoji(category) %> <%= category.presence || 'Uncategorised' %>
          <span class="text-gray-400 normal-case font-normal">(<%= items.count %>)</span>
        </h2>
        <div class="bg-white rounded-xl shadow-sm divide-y">
          <% items.each do |item| %>
            <div class="px-4 py-3 flex items-center gap-3">
              <div class="flex-1 min-w-0">
                <p class="font-medium text-sm text-gray-800 truncate"><%= item.product.name %></p>
                <p class="text-xs text-gray-500"><%= item.product.brand %> · <%= item.product.unit %></p>
              </div>
              <span class="font-mono text-xs text-gray-400"><%= item.product.barcode&.last(8) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @scan_items.empty? %>
      <div class="text-center py-12 text-gray-400">
        <p class="text-4xl mb-3">📋</p>
        <p>No items scanned yet</p>
      </div>
    <% end %>
  </div>
</div>
