<div class="min-h-screen bg-gray-50">
  <div class="bg-blue-700 text-white px-4 py-5 flex items-center gap-3">
    <%= link_to root_path, class: "text-blue-200 text-sm" do %>← Back<% end %>
    <div>
      <h1 class="text-xl font-bold">Store Visits</h1>
      <p class="text-blue-200 text-sm"><%= @scan_sessions.count %> sessions total</p>
    </div>
    <%= link_to new_scan_session_path,
          class: "ml-auto bg-white text-blue-700 font-bold px-4 py-2 rounded-lg text-sm" do %>
      + New
    <% end %>
  </div>

  <div class="px-4 py-4 space-y-3">
    <% if @scan_sessions.empty? %>
      <div class="text-center py-16 text-gray-400">
        <p class="text-4xl mb-3">🗂️</p>
        <p class="font-medium">No sessions yet</p>
        <p class="text-sm mt-1">Start a new store visit to begin scanning</p>
      </div>
    <% else %>
      <% @scan_sessions.each do |session| %>
        <%= link_to scan_session_path(session),
              class: "bg-white rounded-xl p-4 shadow-sm flex items-center gap-3 block" do %>
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-xl">
            🗂️
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-800"><%= session.name %></p>
            <p class="text-xs text-gray-500">
              <%= session.location.presence || 'No location' %>
              · <%= session.scanned_on&.strftime('%d %b %Y') %>
            </p>
          </div>
          <div class="text-right">
            <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded-full">
              <%= session.scan_items.count %> items
            </span>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
