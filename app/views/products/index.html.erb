<div class="min-h-screen bg-gray-50">
  <div class="bg-blue-700 text-white px-4 py-5 flex items-center gap-3">
    <%= link_to root_path, class: "text-blue-200 text-sm" do %>← Back<% end %>
    <div>
      <h1 class="text-xl font-bold">Products</h1>
      <p class="text-blue-200 text-sm"><%= @products.count %> products</p>
    </div>
  </div>

  <div class="px-4 py-4">
    <%= form_with url: products_path, method: :get, class: "mb-4 flex gap-2" do |f| %>
      <%= f.text_field :q, value: params[:q],
            placeholder: "Search products…",
            class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.submit "Search", class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-semibold" %>
    <% end %>

    <% if @products.empty? %>
      <div class="text-center py-16 text-gray-400">
        <p class="text-4xl mb-3">📋</p>
        <p class="font-medium">No products found</p>
      </div>
    <% else %>
      <div class="space-y-2">
        <% @products.each do |product| %>
          <%= link_to product_path(product),
                class: "bg-white rounded-xl p-3 flex items-center gap-3 shadow-sm block" do %>
            <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center text-xl">
              <%= product_emoji(product.category) %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-sm text-gray-800 truncate"><%= product.name %></p>
              <p class="text-xs text-gray-500">
                <%= product.brand.presence || '—' %> · <%= product.category.presence || 'Uncategorised' %>
              </p>
            </div>
            <span class="text-xs text-gray-400 font-mono"><%= product.barcode&.last(6) %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
