<div class="min-h-screen bg-gray-900 text-white flex flex-col">
  <div class="flex items-center gap-3 px-4 py-4 bg-gray-800">
    <% back = params[:session_id].present? ? scan_session_path(params[:session_id]) : products_path %>
    <%= link_to back, class: "text-gray-400" do %>←<% end %>
    <h1 class="font-semibold">Manual Product Entry</h1>
  </div>

  <%= form_with model: @product, class: "px-4 py-6 space-y-4" do |f| %>
    <%= hidden_field_tag :session_id, @session_id %>

    <% if @product.errors.any? %>
      <div class="bg-red-900 border border-red-700 rounded-lg p-3 text-sm text-red-200">
        <% @product.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <label class="text-xs text-gray-400 uppercase block mb-1">Barcode</label>
      <%= f.text_field :barcode,
            class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-yellow-400 font-mono" %>
    </div>

    <div>
      <label class="text-xs text-gray-400 uppercase block mb-1">Product Name *</label>
      <%= f.text_field :name, placeholder: "e.g. Apex Exterior Emulsion",
            class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white" %>
    </div>

    <div>
      <label class="text-xs text-gray-400 uppercase block mb-1">Brand</label>
      <%= f.text_field :brand, placeholder: "e.g. Asian Paints",
            class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white" %>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-xs text-gray-400 uppercase block mb-1">Category</label>
        <%= f.select :category,
              ['Paint','Hardware','Cement','Electrical','Plumbing','Tools','Adhesive','Other'],
              { include_blank: '— Select —' },
              class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-3 py-3 text-white" %>
      </div>
      <div>
        <label class="text-xs text-gray-400 uppercase block mb-1">Sub-Category</label>
        <%= f.text_field :sub_category, placeholder: "e.g. Wall Paint",
              class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-3 py-3 text-white" %>
      </div>
    </div>

    <div>
      <label class="text-xs text-gray-400 uppercase block mb-1">Unit / Size</label>
      <%= f.text_field :unit, placeholder: "e.g. 20 Ltr",
            class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white" %>
    </div>

    <div>
      <label class="text-xs text-gray-400 uppercase block mb-1">Description</label>
      <%= f.text_area :description, rows: 2, placeholder: "Optional product notes…",
            class: "w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white text-sm" %>
    </div>

    <%= f.hidden_field :source, value: 'manual' %>

    <%= f.submit "Save Product",
          class: "w-full bg-green-600 text-white py-4 rounded-xl font-bold text-lg mt-2" %>
  <% end %>
</div>
