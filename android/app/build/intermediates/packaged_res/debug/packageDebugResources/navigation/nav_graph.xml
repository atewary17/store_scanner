<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.storescanner.ui.login.LoginFragment"
        android:label="Sign In">
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.storescanner.ui.dashboard.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboard_to_new_session"
            app:destination="@id/newSessionFragment" />
        <action
            android:id="@+id/action_dashboard_to_sessions"
            app:destination="@id/sessionListFragment" />
    </fragment>

    <fragment
        android:id="@+id/sessionListFragment"
        android:name="com.storescanner.ui.sessions.SessionListFragment"
        android:label="Store Visits">
        <action
            android:id="@+id/action_sessions_to_new_session"
            app:destination="@id/newSessionFragment" />
        <action
            android:id="@+id/action_sessions_to_scanner"
            app:destination="@id/scannerFragment" />
    </fragment>

    <fragment
        android:id="@+id/newSessionFragment"
        android:name="com.storescanner.ui.sessions.NewSessionFragment"
        android:label="New Session">
        <action
            android:id="@+id/action_new_session_to_scanner"
            app:destination="@id/scannerFragment"
            app:popUpTo="@id/newSessionFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/scannerFragment"
        android:name="com.storescanner.ui.scanner.ScannerFragment"
        android:label="Scanner">
        <argument
            android:name="sessionId"
            app:argType="integer" />
        <action
            android:id="@+id/action_scanner_to_approval"
            app:destination="@id/productApprovalFragment" />
    </fragment>

    <fragment
        android:id="@+id/productApprovalFragment"
        android:name="com.storescanner.ui.approval.ProductApprovalFragment"
        android:label="Review Product">
        <argument android:name="sessionId"    app:argType="integer" />
        <argument android:name="barcode"      app:argType="string"  android:defaultValue="" />
        <argument android:name="barcodeType"  app:argType="string"  android:defaultValue="" />
        <argument android:name="name"         app:argType="string"  android:defaultValue="" />
        <argument android:name="brand"        app:argType="string"  android:defaultValue="" />
        <argument android:name="category"     app:argType="string"  android:defaultValue="" />
        <argument android:name="description"  app:argType="string"  android:defaultValue="" />
        <argument android:name="unit"         app:argType="string"  android:defaultValue="" />
        <argument android:name="imageUrl"     app:argType="string"  android:defaultValue="" />
        <argument android:name="source"       app:argType="string"  android:defaultValue="manual" />
        <argument android:name="needsOcr"     app:argType="boolean" android:defaultValue="false" />
    </fragment>

</navigation>
