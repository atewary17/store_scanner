    <color name="text_dim">#9ca3af</color>
    <color name="text_primary">#111827</color>
    <color name="text_secondary">#6b7280</color>
    <color name="text_white">#ffffff</color>
    <string name="app_name">Store Scanner</string>
    <style name="TextAppearance.DarkLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/dark_600</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
    <style name="TextAppearance.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
    <style name="TextAppearance.StatValue" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">28sp</item>
    </style>
    <style name="Theme.StoreScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_700</item>
        <item name="colorPrimaryVariant">@color/blue_600</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/green_600</item>
        <item name="android:windowBackground">@color/page_bg</item>
    </style>
    <style name="Theme.StoreScanner.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_600</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="android:windowBackground">@color/dark_900</item>
        <item name="android:textColor">@color/text_white</item>
    </style>
</resources>